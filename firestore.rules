rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Sites collection: anyone can read and write
    // For a personal tool this is acceptable; add auth rules for production
    match /sites/{siteId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['prompt', 'code', 'createdAt'])
                    && request.resource.data.prompt is string
                    && request.resource.data.prompt.size() < 10000
                    && request.resource.data.code is string
                    && request.resource.data.code.size() < 900000; // ~900KB limit
      allow update, delete: if false; // Immutable history
    }
  }
}
